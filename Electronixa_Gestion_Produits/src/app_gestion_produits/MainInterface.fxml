<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="580.0" prefWidth="960.0"
            minWidth="860.0" minHeight="580.0"
            style="-fx-background-color: #f4f6f9;"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app_gestion_produits.MainInterfaceController">
    <children>

        <!--  TITRE  -->
        <Label layoutX="24.0" layoutY="16.0"
               text="🖥  Gestion des Produits"
               textFill="#2c3e50"
               style="-fx-font-size: 22px; -fx-font-weight: bold;" />

        <Label layoutX="26.0" layoutY="46.0"
               text="Les produits actuels chez Electronixa"
               textFill="#7f8c8d"
               style="-fx-font-size: 12px;" />

        <!--  SÉPARATEUR HORIZONTAL  -->
        <Separator layoutX="24.0" layoutY="72.0"
                   AnchorPane.leftAnchor="24.0"
                   AnchorPane.rightAnchor="24.0" />

        <!-- PANNEAU GAUCHE  -->

        <VBox layoutX="24.0" layoutY="86.0"
              prefWidth="270.0"
              AnchorPane.leftAnchor="24.0"
              AnchorPane.topAnchor="86.0"
              AnchorPane.bottomAnchor="10.0"
              spacing="8.0"
              style="-fx-background-color: white;
                     -fx-padding: 18 16 18 16;
                     -fx-background-radius: 10;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
            <children>

                <Label text="Informations produit"
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #34495e;" />
                <Separator />

                <Label text="Code du produit :"
                       style="-fx-text-fill: #555; -fx-font-size: 12px;" />
                <TextField fx:id="txtCode" promptText="Ex : P001"
                           style="-fx-background-radius: 6; -fx-border-color: #dce1e7;
                                  -fx-border-radius: 6; -fx-padding: 6 10 6 10;" />

                <Label text="Libellé :"
                       style="-fx-text-fill: #555; -fx-font-size: 12px;" />
                <TextField fx:id="txtLibelle" promptText="Ex : Ordinateur portable"
                           style="-fx-background-radius: 6; -fx-border-color: #dce1e7;
                                  -fx-border-radius: 6; -fx-padding: 6 10 6 10;" />

                <Label text="Type :"
                       style="-fx-text-fill: #555; -fx-font-size: 12px;" />
                <ComboBox fx:id="cmbType" prefWidth="238.0"
                          style="-fx-background-radius: 6; -fx-border-color: #dce1e7; -fx-border-radius: 6;" />

                <Label text="Quantité en stock :"
                       style="-fx-text-fill: #555; -fx-font-size: 12px;" />
                <TextField fx:id="txtQuantite" promptText="Ex : 10"
                           style="-fx-background-radius: 6; -fx-border-color: #dce1e7;
                                  -fx-border-radius: 6; -fx-padding: 6 10 6 10;" />

                <CheckBox fx:id="chkDisponible" mnemonicParsing="false"
                          text="Disponible immédiatement"
                          style="-fx-text-fill: #555;" />

                <Separator />

                <!-- AJOUTER / MODIFIER -->
                <HBox spacing="8.0">
                    <children>
                        <Button fx:id="btnAjouter" onAction="#handleAjouter"
                                mnemonicParsing="false" prefWidth="115.0" text="✚  Ajouter"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;" />
                        <Button fx:id="btnModifier" onAction="#handleModifier"
                                mnemonicParsing="false" prefWidth="115.0" text="✎  Modifier"
                                style="-fx-background-color: #2980b9; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;" />
                    </children>
                </HBox>

                <!-- SUPPRIMER / ACTUALISER -->
                <HBox spacing="8.0">
                    <children>
                        <Button fx:id="btnSupprimer" onAction="#handleSupprimer"
                                mnemonicParsing="false" prefWidth="115.0" text="✖  Supprimer"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;" />
                        <Button fx:id="btnActualiser" onAction="#handleActualiser"
                                mnemonicParsing="false" prefWidth="115.0" text="↺  Actualiser"
                                style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;" />
                    </children>
                </HBox>

                <!-- VIDER -->
                <Button fx:id="btnVider" onAction="#handleVider"
                        mnemonicParsing="false" prefWidth="238.0" text="⊘  Vider le formulaire"
                        style="-fx-background-color: transparent; -fx-text-fill: #95a5a6;
                               -fx-border-color: #dce1e7; -fx-border-radius: 7;
                               -fx-background-radius: 7; -fx-cursor: hand; -fx-font-size: 11px;" />

                <!-- ± AJUSTER STOCK (visible seulement quand un produit est sélectionné) -->
                <Label fx:id="lblStockActuel" text=""
                       visible="false" managed="false"
                       style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;
                              -fx-font-style: italic; -fx-padding: 0 0 0 2;" />
                <TextField fx:id="txtAjustement"
                           visible="false" managed="false"
                           style="-fx-background-radius: 6; -fx-border-color: #f39c12;
                                  -fx-border-radius: 6; -fx-padding: 6 10 6 10;" />
                <Button fx:id="btnAjusterStock" onAction="#handleAjusterStock"
                        mnemonicParsing="false" prefWidth="238.0"
                        text="±  Ajuster le stock"
                        visible="false" managed="false"
                        style="-fx-background-color: #f39c12; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 7;
                               -fx-cursor: hand; -fx-font-size: 12px;" />

                <Separator />

                <!--  NOUVEAUX BOUTONS  -->
                <Label text="Exports &amp; Historique"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #34495e;" />

                <!-- EXPORT CSV -->
                <Button fx:id="btnExportCSV" onAction="#handleExportCSV"
                        mnemonicParsing="false" prefWidth="238.0" text="📄  Exporter CSV"
                        style="-fx-background-color: #16a085; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;" />

                <!-- EXPORT PDF -->
                <Button fx:id="btnExportPDF" onAction="#handleExportPDF"
                        mnemonicParsing="false" prefWidth="238.0" text="🖨  Exporter PDF"
                        style="-fx-background-color: #8e44ad; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;" />

                <!-- HISTORIQUE -->
                <Button fx:id="btnHistorique" onAction="#handleHistorique"
                        mnemonicParsing="false" prefWidth="238.0" text="🕓  Historique des actions"
                        style="-fx-background-color: #d35400; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 7; -fx-cursor: hand;" />

            </children>
        </VBox>


        <!-- PANNEAU DROIT -->

        <VBox layoutX="314.0" layoutY="86.0"
              prefWidth="522.0"
              AnchorPane.leftAnchor="314.0"
              AnchorPane.rightAnchor="24.0"
              AnchorPane.topAnchor="86.0"
              AnchorPane.bottomAnchor="10.0"
              spacing="10.0">
            <children>

                <!-- BARRE DE RECHERCHE -->
                <HBox spacing="10.0" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-padding: 10 14 10 14;
                             -fx-background-radius: 10;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                    <children>
                        <Label text="🔍" style="-fx-font-size: 16px;" />
                        <TextField fx:id="txtRecherche"
                                   promptText="Rechercher par libellé ou par type..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: #f4f6f9; -fx-background-radius: 6;
                                          -fx-border-color: transparent; -fx-padding: 7 10 7 10;
                                          -fx-font-size: 13px;" />
                        <Button fx:id="btnEffacerRecherche" onAction="#handleEffacerRecherche"
                                mnemonicParsing="false" text="✕"
                                style="-fx-background-color: #ecf0f1; -fx-text-fill: #7f8c8d;
                                       -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 11px;" />
                    </children>
                </HBox>

                <!-- TABLEAU PRODUITS -->
                <TableView fx:id="tableProduits"
                           prefHeight="430.0" prefWidth="522.0"
                           VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-radius: 10;
                                  -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                    <columns>
                        <TableColumn fx:id="colId"      prefWidth="55.0"  text="ID"
                                     style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colCode"    prefWidth="90.0"  text="Code" />
                        <TableColumn fx:id="colLibelle" prefWidth="200.0" text="Libellé" />
                        <TableColumn fx:id="colType"    prefWidth="130.0" text="Type" />
                        <TableColumn fx:id="colStock"   prefWidth="80.0"  text="Stock"
                                     style="-fx-alignment: CENTER;" />
                        <TableColumn fx:id="colDispo"   prefWidth="90.0"  text="Disponible"
                                     style="-fx-alignment: CENTER;" />
                    </columns>
                    <placeholder>
                        <Label text="Aucun produit trouvé."
                               style="-fx-text-fill: #bdc3c7; -fx-font-size: 14px;" />
                    </placeholder>
                </TableView>

                <!-- COMPTEUR -->
                <Label fx:id="lblCompteur" text="0 produit(s) affiché(s)"
                       style="-fx-text-fill: #95a5a6; -fx-font-size: 11px; -fx-padding: 0 4 0 4;" />

            </children>
        </VBox>

    </children>
</AnchorPane>
